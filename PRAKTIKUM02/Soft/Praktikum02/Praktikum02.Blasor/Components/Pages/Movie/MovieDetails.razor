@rendermode InteractiveServer
@page "/movies/details/{id:guid}"
@using Microsoft.EntityFrameworkCore
@using Praktikum02.Blasor.Components.Shared
@using Praktikum02.Blasor.Data
@using Praktikum02.Blasor.Domain
@inject IMoviesRepo repo
@inject NavigationManager Nav

<PageTitle>Movie details</PageTitle>

<h1>Movie details</h1>

@if (_movie == null)
{
    <p>Loading...</p>
}
else
{
    <MyViewItem Label="Title" Value="@_movie.Title" />
    <MyViewItem Label="Release date" Value="@_movie.ReleaseDate.ToString("yyyy-MM-dd")" />
    <MyViewItem Label="Genre" Value="@_movie.Genre" />
    <MyViewItem Label="Price" Value="@_movie.Price.ToString()" />

    <button class="btn btn-secondary mt-3" @onclick="Back">Back</button>
}

@code {
    [Parameter] public Guid id { get; set; }

    private Movie? _movie;

    protected override async Task OnInitializedAsync()
    {
        _movie = await repo.GetAsync(id);
    }

    private void Back()
    {
        Nav.NavigateTo("/movies");
    }
}