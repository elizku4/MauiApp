@rendermode InteractiveServer
@page "/movies/delete/{id:int}"
@using Microsoft.EntityFrameworkCore
@using Praktikum02.Blasor.Components.Shared
@using Praktikum02.Blasor.Data
@inject Praktikum02.Blasor.Data.MovieContext Db
@inject NavigationManager Nav

<PageTitle>Delete movie</PageTitle>

<h1>Delete movie</h1>

@if (_movie == null)
{
    <p>Loading...</p>
}
else
{
    <MyViewItem Label="Title" Value="@_movie.Title" />
    <MyViewItem Label="Release date" Value="@_movie.ReleaseDate.ToString("yyyy-MM-dd")" />
    <MyViewItem Label="Genre" Value="@_movie.Genre" />
    <MyViewItem Label="Price" Value="@_movie.Price.ToString()" />

    <button class="btn btn-danger mt-3" @onclick="Delete">Delete</button>
    <button class="btn btn-secondary mt-3 ms-2" @onclick="Back">Cancel</button>
}

@code {
    [Parameter] public int id { get; set; }

    private Movie? _movie;

    protected override async Task OnInitializedAsync()
    {
        _movie = await Db.Movies.FirstOrDefaultAsync(m => m.Id == id);
    }

    private async Task Delete()
    {
        if (_movie != null)
        {
            Db.Movies.Remove(_movie);
            await Db.SaveChangesAsync();
        }

        Nav.NavigateTo("/movies");
    }

    private void Back()
    {
        Nav.NavigateTo("/movies");
    }
}