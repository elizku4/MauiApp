@rendermode InteractiveServer
@page "/currencies/delete/{id:guid}"

@using Praktikum02.Blasor.Data
@using Praktikum02.Blasor.Domain
@inject ICurrenciesRepo repo
@inject NavigationManager Nav

<h1>Delete currency</h1>

@if (_currency != null)
{
    <p>Delete <b>@_currency.Code</b> - @_currency.Name ?</p>

    <button class="btn btn-danger" @onclick="Delete">Delete</button>
    <button class="btn btn-secondary ms-2" @onclick="Cancel">Cancel</button>
}

@code {
    [Parameter] public Guid id { get; set; }

    private Currency? _currency;

    protected override async Task OnInitializedAsync()
    {
        _currency = await repo.GetAsync(id);
    }

    private async Task Delete()
    {
        await repo.DeleteAsync(id);
        Nav.NavigateTo("/currencies");
    }

    private void Cancel() => Nav.NavigateTo("/currencies");
}