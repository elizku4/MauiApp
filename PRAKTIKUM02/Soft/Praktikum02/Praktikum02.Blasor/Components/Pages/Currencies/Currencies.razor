@rendermode InteractiveServer
@page "/currencies"
@using Microsoft.EntityFrameworkCore
@using Praktikum02.Blasor.Data
@using Praktikum02.Blasor.Components.Shared
@inject Praktikum02.Blasor.Data.MovieContext Db

<PageTitle>Currencies</PageTitle>

<h1>Currencies</h1>

<NavLink class="btn btn-primary" href="/currencies/create">
    Add currency
</NavLink>

@if (_currencies is null)
{
    <p><em>Loading...</em></p>
}
else if (_currencies.Count == 0)
{
    <p>No currencies yet. Click <b>Add currency</b>.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Symbol</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in _currencies)
            {
                <tr>
                    <td>@c.Code</td>
                    <td>@c.Name</td>
                    <td>@c.Symbol</td>
                    <td class="text-nowrap">
                        <NavLink class="btn btn-sm btn-primary me-1" href="@($"/currencies/edit/{c.Id}")">Edit</NavLink>
                        <NavLink class="btn btn-sm btn-secondary me-1" href="@($"/currencies/details/{c.Id}")">Details</NavLink>
                        <NavLink class="btn btn-sm btn-danger" href="@($"/currencies/delete/{c.Id}")">Delete</NavLink>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Currency>? _currencies;

    protected override async Task OnInitializedAsync()
    {
        _currencies = await Db.Currencies
            .AsNoTracking()
            .OrderBy(c => c.Code)
            .ToListAsync();
    }
}