@rendermode InteractiveServer
@page "/currencies/edit/{id:guid}"
@using Praktikum02.Aids
@using Praktikum02.Blasor.Data
@using Praktikum02.Blasor.Domain
@inject ICurrenciesRepo repo
@inject NavigationManager Nav

<h1>Edit currency</h1>

@if (_currency != null && adapter != null)
{
    <EditForm Model="@_currency" OnSubmit="@HandleSubmit">

        @foreach (var prop in adapter.Properties)
        {
            if (prop.PropInfo.Name == "Id"
            || prop.PropInfo.Name == "Timestamp"
            || prop.PropInfo.Name == "ValidFrom"
            || prop.PropInfo.Name == "ValidTo")
                continue;

            <div class="mb-3">
                <label>@prop.PropInfo.Name</label>

                @if (prop.PropType == typeof(DateTime) || prop.PropType == typeof(DateTime?))
                {
                    <input class="form-control"
                           value="@prop.PropValue"
                           @onchange="e =>
                           {
                               if (DateTime.TryParse(e.Value?.ToString(), out var dt))
                                   prop.SetValue(dt);
                           }" />
                }
                else
                {
                    <input class="form-control"
                           value="@prop.PropValue"
                           @onchange="e => prop.SetValue(e.Value?.ToString())" />
                }
            </div>
        }

        <button class="btn btn-success" type="submit">Save</button>
        <button class="btn btn-secondary ms-2" type="button" @onclick="Cancel">Cancel</button>

    </EditForm>
}

@code {
    [Parameter] public Guid id { get; set; }

    private Currency? _currency;
    private EditorAdapter? adapter;

    protected override async Task OnInitializedAsync()
    {
        _currency = await repo.GetAsync(id);

        if (_currency != null)
            adapter = new EditorAdapter(_currency);
    }

    private async Task HandleSubmit()
    {
        if (_currency != null)
        {
            await repo.UpdateAsync(_currency);
        }

        Nav.NavigateTo("/currencies");
    }

    private void Cancel() => Nav.NavigateTo("/currencies");
}